{
  "endpoints": [
    {
      "method": "GET",
      "path": "/api/status",
      "description": "Daemon status, uptime, and collector intervals",
      "category": "Status \u0026 Config",
      "response": "StatusResponse"
    },
    {
      "method": "GET",
      "path": "/api/config",
      "description": "Full daemon, alerts, and TUI configuration",
      "category": "Status \u0026 Config",
      "response": "ConfigResponse"
    },
    {
      "method": "GET",
      "path": "/api/metrics/cpu",
      "description": "Per-core CPU usage percentages",
      "category": "Live Metrics",
      "response": "CPUResponse",
      "notes": [
        "ETag caching"
      ]
    },
    {
      "method": "GET",
      "path": "/api/metrics/memory",
      "description": "Memory and swap usage",
      "category": "Live Metrics",
      "response": "MemoryMetric",
      "notes": [
        "ETag caching"
      ]
    },
    {
      "method": "GET",
      "path": "/api/metrics/disk",
